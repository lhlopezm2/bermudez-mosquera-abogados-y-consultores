# Copiar este archivo como .env.local para desarrollo

# URL pública final del sitio (para metadatos SEO y sitemap)
NEXT_PUBLIC_SITE_URL=https://usuario.github.io/nombre-del-repositorio

# Sub-ruta cuando se despliega como GitHub Pages de proyecto (ej: /nombre-del-repositorio)
NEXT_PUBLIC_BASE_PATH=

# Endpoint de Formspree (u otro proveedor) para el formulario de contacto
NEXT_PUBLIC_FORM_ENDPOINT=
